# Backend Environment Variables
# Default local setup uses SQLite so a fresh clone can run without Supabase/Postgres.
# Later, replace DATABASE_URL with your Supabase/Postgres connection string.
DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET="change-this-in-production"

# Optional payment configuration
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_CURRENCY="INR"

# Optional email configuration (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@restaurant.com"
SMTP_USE_TLS="1"

# Optional email configuration (Resend)
RESEND_API_KEY=""
RESEND_FROM="Restaurant <onboarding@resend.dev>"

# Server Configuration
PORT="3001"
NODE_ENV="development"
